# RIOT API Key - Get yours at https://developer.riotgames.com/
RIOT_API_KEY=RGAPI-your-key-here

# Players list: "gameName#tagLine" separated by commas
# IMPORTANTE: Usar comillas dobles porque el # inicia comentarios en .env
PLAYERS="Player1#LAS,Player2#LAS"

# Server port
PORT=3001

# Client URL (for CORS in production)
CLIENT_URL=http://localhost:5173
